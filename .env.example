# ============================================
# ERP Terrenos - Variables de Entorno
# ============================================

# Django
DJANGO_SECRET_KEY=tu-clave-secreta-aqui
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de Datos PostgreSQL
DATABASE_URL=postgres://erp_user:erp_password@localhost:5432/erp_terrenos
POSTGRES_DB=erp_terrenos
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# FEL / SAT Guatemala
FEL_NIT_EMISOR=
FEL_CERTIFICADOR_URL=
FEL_API_KEY=

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Google Maps
GOOGLE_MAPS_API_KEY=
